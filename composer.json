{
    "name": "dbravoan/dba-stack",
    "type": "project",
    "description": "High-performance DDD & Hexagonal Architecture boilerplate for Laravel 12.",
    "keywords": ["laravel", "ddd", "hexagonal-architecture", "php8.4", "excellence"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "dbravoan/dba-ddd-skeleton": "^1.0",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^12.0",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/passport": "^12.0",
        "laravel/tinker": "^2.8",
        "lambdish/phunctional": "^2.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "larastan/larastan": "^3.0",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "DbaStack\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php -r \"if (file_exists('artisan')) { passthru('php artisan package:discover --ansi', $exitCode); exit($exitCode); }\""
        ],
        "post-update-cmd": [
            "@php -r \"if (file_exists('artisan')) { passthru('php artisan vendor:publish --tag=laravel-assets --ansi --force', $exitCode); exit($exitCode); }\""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php -r \"if (file_exists('artisan')) { passthru('php artisan key:generate --ansi', $exitCode); exit($exitCode); }\""
        ],
        "lint": "pint",
        "test": "phpunit",
        "phpstan": "phpstan analyse src --level=max"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}