# --- DBA-STACK CONFIGURATION ---
# Use a unique project name to isolate Docker containers/networks
COMPOSE_PROJECT_NAME=dba-stack-boilerplate

APP_NAME=DBA-Stack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# --- DOCKER / SAIL PORTS ---
# Change these if you run multiple projects simultaneously
APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379

# --- DATABASE ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dba_stack_db
DB_USERNAME=sail
DB_PASSWORD=password

# --- CACHE & QUEUE ---
# Required for the Command Bus and Event Bus implementations
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# --- REDIS ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- PASSPORT ---
# Configuration for API Authentication
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# --- LOGGING ---
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug